<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/urlBox"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="Вставьте ссылку..."
                android:inputType="textUri"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textColor="#111111"
                android:textColorHint="#777777"
                android:textSize="18sp" />

            <Button
                android:id="@+id/pasteButton"
                android:layout_width="140dp"
                android:layout_height="56dp"
                android:layout_marginStart="10dp"
                android:text="ВСТАВИТЬ"
                android:background="@drawable/btn_mc_stone"
                android:textColor="#FFFFFF"
                android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/findButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:enabled="false"
            android:text="ИСКАТЬ ВИДЕО"
            android:background="@drawable/btn_mc_youtube"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/infoPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:layout_width="240dp"
                    android:layout_height="135dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp">
                    
                    <ImageView
                        android:id="@+id/previewImage"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_media_play" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="20dp"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/videoTitle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Название видео"
                        android:textColor="#111111"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/videoDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:maxLines="3"
                        android:text="Описание видео"
                        android:textColor="#555555"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/videoAuthor"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="Автор:"
                        android:textColor="#444444"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/videoDuration"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Время:"
                        android:textColor="#808080"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="#DCDCDC" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Выберите тип скачивания:"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/downloadTypeSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/qualityOrBitrateLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Выберите качество:"
                android:textColor="#111111"
                android:textSize="17sp"
                android:textStyle="bold" />

            <Spinner
                android:id="@+id/qualityOrBitrateSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp" />

            <TextView
                android:id="@+id/audioLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Выберите звуковую дорожку:"
                android:textColor="#111111"
                android:textSize="17sp"
                android:textStyle="bold"
                android:visibility="gone" />

            <Spinner
                android:id="@+id/audioSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="6dp"
                android:visibility="gone" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="20dp"
                android:background="#DCDCDC" />

            <Button
                android:id="@+id/downloadButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:enabled="false"
                android:text="СКАЧАТЬ РЕСУРСЫ"
                android:background="@drawable/btn_mc_green"
                android:textColor="#55FF55"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>