<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#E8F0FE" /> <stroke android:width="1dp" android:color="#1a73e8" /> <corners android:radius="4dp" /> </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" /> <stroke android:width="1dp" android:color="#1a73e8" /> <corners android:radius="4dp" /> </shape>
    </item>
</selector>